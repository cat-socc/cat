# Python caches.
__pycache__/
*.py[cod]
*$py.class

# Local environment and parameter overrides.
.env
.env.*
*.local

# Old benchmark tree. Paper reproduction scripts now live under bench/.
benchmarks/

# Intermediate benchmark result directories.
**/res/
**/results/
**/reproduce_results/

# Intermediate object-map outputs generated by Aget data preparation.
# The bundled write pattern under bench/Aget/write_patterns/ is the source of truth.
bench/Aget/object_map_res/
bench/publish/object_map_res/

# Temporary fio/test payloads and logs.
**/testfile
*.tmp
*.log

# OS/editor noise.
.DS_Store
*~
